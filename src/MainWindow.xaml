<Window x:Class="MewgenicsSaveGuardian.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MewgenicsSaveGuardian.ViewModels"
        xmlns:loc="clr-namespace:MewgenicsSaveGuardian.Localization"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="Bye Bye Steven"
        Icon="Resources/app.ico"
        Width="520" Height="720"
        MinWidth="460" MinHeight="580"
        Background="{StaticResource BgMediumBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
        <DockPanel Margin="24,20,24,24">

            <!-- ==================== Header ==================== -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding [AppTitle], Source={x:Static loc:Loc.Instance}}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,3"/>
                    <TextBlock Text="{Binding [AppSubtitle], Source={x:Static loc:Loc.Instance}}"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"/>
                </StackPanel>

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AvailableLanguages}"
                          SelectedItem="{Binding SelectedLanguage}"
                          DisplayMemberPath="Name"
                          Style="{StaticResource DarkComboBox}"
                          Width="100" VerticalAlignment="Top"/>
            </Grid>

            <Rectangle DockPanel.Dock="Top" Height="1"
                       Fill="{StaticResource BorderSubtleBrush}" Margin="0,10,0,0"/>

            <!-- ==================== Collapsible Paths Header ==================== -->
            <ToggleButton DockPanel.Dock="Top" IsChecked="{Binding IsPathsExpanded}"
                          Cursor="Hand" Margin="0,0,0,0">
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Padding="0,12,0,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="chevron" Text="&#x25BC;"
                                           FontSize="8" Margin="0,1,6,0"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding [SectionPaths], Source={x:Static loc:Loc.Instance}}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="Segoe UI" FontSize="10.5"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="chevron" Property="Text" Value="&#x25B6;"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </ToggleButton.Template>
            </ToggleButton>

            <!-- ==================== Paths Content (collapsible) ==================== -->
            <StackPanel DockPanel.Dock="Top"
                        Visibility="{Binding IsPathsExpanded, Converter={StaticResource BoolToVis}}">

                <!-- Save File Path -->
                <TextBlock Text="{Binding [SectionSaveFile], Source={x:Static loc:Loc.Instance}}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontFamily="Segoe UI" FontSize="10.5" FontWeight="SemiBold"
                           Margin="0,4,0,8"/>
                <DockPanel Margin="0,0,0,6">
                    <Button Content="{Binding [BtnBrowse], Source={x:Static loc:Loc.Instance}}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource SecondaryButton}"
                            Click="OnBrowseClick" Margin="8,0,0,0"/>
                    <Button Content="{Binding [BtnAuto], Source={x:Static loc:Loc.Instance}}"
                            DockPanel.Dock="Right"
                            Command="{Binding AutoFindPathCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/>
                    <TextBox Text="{Binding SaveFilePath, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}"
                             IsReadOnly="True"/>
                </DockPanel>

                <!-- Game Executable Path -->
                <TextBlock Text="{Binding [LblGameExe], Source={x:Static loc:Loc.Instance}}"
                           Style="{StaticResource StatusLabel}" Margin="0,4,0,6"/>
                <DockPanel Margin="0,0,0,6">
                    <Button Content="{Binding [BtnBrowseExe], Source={x:Static loc:Loc.Instance}}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource SecondaryButton}"
                            Click="OnBrowseExeClick" Margin="8,0,0,0"/>
                    <Button Content="{Binding [BtnAutoExe], Source={x:Static loc:Loc.Instance}}"
                            DockPanel.Dock="Right"
                            Command="{Binding AutoDetectGameExeCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/>
                    <TextBox Text="{Binding GameExePath, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}"
                             IsReadOnly="True"/>
                </DockPanel>
            </StackPanel>

            <!-- ==================== Status Bar (bottom) ==================== -->
            <Border DockPanel.Dock="Bottom"
                    Background="{StaticResource BgDeepBrush}" CornerRadius="3"
                    Padding="10,7" Margin="0,12,0,0"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource AccentYellowBrush}"
                           FontFamily="Consolas"
                           FontSize="11"/>
            </Border>

            <!-- ==================== Tab Control ==================== -->
            <TabControl Style="{StaticResource DarkTabControl}" Margin="0,6,0,0">

                <!-- ===== Tab 1: Status & Actions ===== -->
                <TabItem Style="{StaticResource DarkTabItem}"
                         Header="{Binding [TabStatus], Source={x:Static loc:Loc.Instance}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <!-- Status Panel -->
                            <Border Background="{StaticResource BgDarkBrush}" CornerRadius="4"
                                    Padding="16,14" Margin="0,4,0,0"
                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="26"/>
                                        <RowDefinition Height="26"/>
                                        <RowDefinition Height="26"/>
                                        <RowDefinition Height="26"/>
                                        <RowDefinition Height="26"/>
                                        <RowDefinition Height="26"/>
                                    </Grid.RowDefinitions>

                                    <!-- Game Process -->
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="{Binding [LblGameProcess], Source={x:Static loc:Loc.Instance}}"
                                               Style="{StaticResource StatusLabel}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource StatusValue}">
                                                <Setter Property="Text" Value="{Binding [ValNotRunning], Source={x:Static loc:Loc.Instance}}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGameRunning}" Value="True">
                                                        <Setter Property="Text" Value="{Binding [ValRunning], Source={x:Static loc:Loc.Instance}}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Deja Vu Flag -->
                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="{Binding [LblPenaltyFlag], Source={x:Static loc:Loc.Instance}}"
                                               Style="{StaticResource StatusLabel}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource StatusValue}">
                                                <Setter Property="Text" Value="{Binding [ValSafe], Source={x:Static loc:Loc.Instance}}"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPenaltyActive}" Value="True">
                                                        <Setter Property="Text" Value="{Binding [ValActive], Source={x:Static loc:Loc.Instance}}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Steven Met -->
                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="{Binding [LblStevenMet], Source={x:Static loc:Loc.Instance}}"
                                               Style="{StaticResource StatusLabel}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource StatusValue}">
                                                <Setter Property="Text" Value="{Binding [ValNo], Source={x:Static loc:Loc.Instance}}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StevenMet}" Value="True">
                                                        <Setter Property="Text" Value="{Binding [ValYes], Source={x:Static loc:Loc.Instance}}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Steven Strikes -->
                                    <TextBlock Grid.Row="3" Grid.Column="0"
                                               Text="{Binding [LblStevenStrikes], Source={x:Static loc:Loc.Instance}}"
                                               Style="{StaticResource StatusLabel}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1"
                                               Text="{Binding StevenStrikes}"
                                               Style="{StaticResource StatusValue}"/>

                                    <!-- Current Day -->
                                    <TextBlock Grid.Row="4" Grid.Column="0"
                                               Text="{Binding [LblCurrentDay], Source={x:Static loc:Loc.Instance}}"
                                               Style="{StaticResource StatusLabel}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1"
                                               Text="{Binding CurrentDay}"
                                               Style="{StaticResource StatusValue}"/>

                                    <!-- On Adventure -->
                                    <TextBlock Grid.Row="5" Grid.Column="0"
                                               Text="{Binding [LblOnAdventure], Source={x:Static loc:Loc.Instance}}"
                                               Style="{StaticResource StatusLabel}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource StatusValue}">
                                                <Setter Property="Text" Value="{Binding [ValNo], Source={x:Static loc:Loc.Instance}}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding OnAdventure}" Value="True">
                                                        <Setter Property="Text" Value="{Binding [ValYes], Source={x:Static loc:Loc.Instance}}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource AccentYellowBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <!-- Steven Context Panel -->
                            <Border CornerRadius="4" Padding="12,9" Margin="0,8,0,0"
                                    BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource BgDeepBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPenaltyActive}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentRedBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="11.5" FontStyle="Italic">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding [StevenSafe], Source={x:Static loc:Loc.Instance}}"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPenaltyActive}" Value="True">
                                                    <Setter Property="Text" Value="{Binding [StevenWatch], Source={x:Static loc:Loc.Instance}}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" Margin="0,14,0,0"/>

                            <!-- Actions -->
                            <TextBlock Text="{Binding [SectionActions], Source={x:Static loc:Loc.Instance}}"
                                       Style="{StaticResource SectionHeader}"/>

                            <!-- Remove Penalty -->
                            <Button Content="{Binding [BtnRemovePenalty], Source={x:Static loc:Loc.Instance}}"
                                    Command="{Binding RemovePenaltyCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    FontSize="14" Padding="0,11"
                                    HorizontalAlignment="Stretch" Margin="0,0,0,8"/>

                            <!-- Restart & Clear -->
                            <Button Content="{Binding [BtnRestartClear], Source={x:Static loc:Loc.Instance}}"
                                    Command="{Binding RestartAndClearCommand}"
                                    Style="{StaticResource DangerButton}"
                                    FontSize="13" Padding="0,9"
                                    HorizontalAlignment="Stretch" Margin="0,0,0,10"/>

                            <!-- Options -->
                            <CheckBox Content="{Binding [ChkAutoRelaunch], Source={x:Static loc:Loc.Instance}}"
                                      IsChecked="{Binding AutoRelaunchGame}"
                                      Style="{StaticResource DarkCheckBox}"
                                      Margin="0,0,0,10"/>

                            <!-- Relaunch Game -->
                            <Button Content="{Binding [BtnRelaunchGame], Source={x:Static loc:Loc.Instance}}"
                                    Command="{Binding LaunchGameCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Left"/>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ===== Tab 2: Backups ===== -->
                <TabItem Style="{StaticResource DarkTabItem}"
                         Header="{Binding [TabBackups], Source={x:Static loc:Loc.Instance}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <DataGrid ItemsSource="{Binding Backups}"
                                      SelectedItem="{Binding SelectedBackup}"
                                      Style="{StaticResource DarkDataGrid}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      Height="200" Margin="0,4,0,10">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Width="*"
                                                        Binding="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss'}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{Binding [ColTime], Source={x:Static loc:Loc.Instance}}"/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="45"
                                                        Binding="{Binding CurrentDay}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{Binding [ColDay], Source={x:Static loc:Loc.Instance}}"/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="45"
                                                        Binding="{Binding SaveScumFlag}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{Binding [ColFlag], Source={x:Static loc:Loc.Instance}}"/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="65"
                                                        Binding="{Binding FileSizeBytes, StringFormat='{}{0:N0} B'}">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{Binding [ColSize], Source={x:Static loc:Loc.Instance}}"/>
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                <Button Content="{Binding [BtnRestoreSelected], Source={x:Static loc:Loc.Instance}}"
                                        Command="{Binding RestoreBackupCommand}"
                                        Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                                <Button Content="{Binding [BtnCreateBackup], Source={x:Static loc:Loc.Instance}}"
                                        Command="{Binding CreateBackupCommand}"
                                        Style="{StaticResource SecondaryButton}"/>
                            </StackPanel>

                            <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" Margin="0,14,0,0"/>

                            <!-- Settings -->
                            <TextBlock Text="{Binding [SectionSettings], Source={x:Static loc:Loc.Instance}}"
                                       Style="{StaticResource SectionHeader}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="{Binding [LblMaxBackups], Source={x:Static loc:Loc.Instance}}"
                                           Style="{StaticResource StatusLabel}" Margin="0,0,10,0"/>
                                <ComboBox SelectedItem="{Binding MaxBackups}" Width="55"
                                          Style="{StaticResource DarkComboBox}">
                                    <sys:Int32>3</sys:Int32>
                                    <sys:Int32>5</sys:Int32>
                                    <sys:Int32>10</sys:Int32>
                                    <sys:Int32>20</sys:Int32>
                                </ComboBox>
                            </StackPanel>


                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ===== Tab 3: Tools ===== -->
                <TabItem Style="{StaticResource DarkTabItem}"
                         Header="{Binding [TabTools], Source={x:Static loc:Loc.Instance}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <!-- Speed Control Section -->
                            <TextBlock Text="{Binding [SectionSpeed], Source={x:Static loc:Loc.Instance}}"
                                       Style="{StaticResource SectionHeader}" Margin="0,10,0,10"/>

                            <Border Background="{StaticResource BgDarkBrush}" CornerRadius="4"
                                    Padding="16,14" Margin="0,0,0,0"
                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                    BorderThickness="1">
                                <StackPanel>

                                    <!-- Enable Checkbox -->
                                    <CheckBox Content="{Binding [ChkSpeedEnabled], Source={x:Static loc:Loc.Instance}}"
                                              IsChecked="{Binding SpeedEnabled}"
                                              Style="{StaticResource DarkCheckBox}"
                                              Margin="0,0,0,14"/>

                                    <!-- Speed Label + Value -->
                                    <DockPanel Margin="0,0,0,6">
                                        <TextBlock Text="{Binding [LblSpeed], Source={x:Static loc:Loc.Instance}}"
                                                   Style="{StaticResource StatusLabel}"
                                                   DockPanel.Dock="Left" Margin="0,0,12,0"/>
                                        <TextBox Text="{Binding SpeedMultiplier, StringFormat='{}{0:F1}', UpdateSourceTrigger=LostFocus}"
                                                 Style="{StaticResource DarkTextBox}"
                                                 DockPanel.Dock="Right"
                                                 Width="60" Padding="6,5"
                                                 HorizontalContentAlignment="Center"
                                                 FontSize="12"/>
                                        <Slider Value="{Binding SpeedMultiplier}"
                                                Style="{StaticResource DarkSlider}"
                                                Minimum="0.1" Maximum="10"
                                                TickFrequency="0.1"
                                                IsSnapToTickEnabled="True"
                                                Margin="0,0,10,0"/>
                                    </DockPanel>

                                    <!-- Apply Button -->
                                    <Button Content="Apply"
                                            Command="{Binding ApplySpeedCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            HorizontalAlignment="Left"
                                            Padding="24,8" Margin="0,10,0,0"/>

                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>

        </DockPanel>
    </Border>
</Window>
